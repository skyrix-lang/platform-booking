{
  "extends": "../../tsconfig.json",
  "include": ["src", "vite.config.mts"],
  "compilerOptions": {
    "composite": true,
    "allowImportingTsExtensions": true,
    "skipDefaultLibCheck": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "references": [
    { "path": "../../packages/shared" }
  ]
}
