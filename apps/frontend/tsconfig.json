{
  "extends": "../../tsconfig.json",
  "include": ["src", "vite.config.mts"],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "skipDefaultLibCheck": true,
    "jsx": "react-jsx",
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
